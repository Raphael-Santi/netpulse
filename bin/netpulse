#!/usr/bin/env php
<?php

declare(strict_types=1);

use NetPulse\Cli\Application;

foreach ([__DIR__ . '/../vendor/autoload.php', __DIR__ . '/../../../autoload.php'] as $autoload) {
    if (is_file($autoload)) {
        require $autoload;

        break;
    }
}

/** @var list<string> $argv */
exit((new Application())->run($argv));
